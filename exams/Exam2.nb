Cell[TextData[{
 "You do not need the entries with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"-", "\[Alpha]"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "62683622-4670-4fc2-9dbf-88e93b45b41c"],
 " filled in instead of \[Alpha]!\n\nInstead, when you need entries like ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"<", 
     RowBox[{"-", "S"}]}], "|", 
    RowBox[{
     RowBox[{"0", "T"}], ">"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "3e98dc76-2703-4b6b-95ec-6b9df1b06289"],
 ", you use the general principle: ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"<", "\[Psi]"}], "|", 
     RowBox[{"\[Chi]", ">"}]}], " ", "=", 
    RowBox[{
     RowBox[{"<", "\[Chi]"}], "|", 
     RowBox[{"\[Psi]", 
      SuperscriptBox[">", "*"]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d4bf6f51-b781-48fa-ab99-5d542ef3af65"],
 " . Since all of the table entries are real, that is simple!"
}], "Text",
 CellChangeTimes->{{3.9832595847010317`*^9, 3.9832596856560507`*^9}, {
  3.983259738835363*^9, 3.983259743889512*^9}, {3.983263537108054*^9, 
  3.983263541157098*^9}, {3.983263782626004*^9, 3.983264059474539*^9}, {
  3.9832645604293756`*^9, 3.983264561237936*^9}, {3.983269365422933*^9, 
  3.983269371218481*^9}, {3.9832708486422653`*^9, 
  3.983270860216282*^9}},ExpressionUUID->"094fc4e5-fb80-40fe-b936-\
6b2dd2d997a1"],

Cell["", "PageBreak",
 PageBreakBelow->True,ExpressionUUID->"10754c3e-f59b-4502-913a-fcd7164e0492"]
}, Open  ]],

