Cell[TextData[{
 "(a) Add and subtract these two equations to get differential equations \
involving only ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["C", "1"], "+", 
    SubscriptBox["C", "2"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4d36b8e4-4335-4148-9625-9d0ccb7be760"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["C", "1"], "-", 
    SubscriptBox["C", "2"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5437d491-3619-407d-a7b5-9c0df1a9881d"],
 ". The two equations are independent!\n\n(b) Solve each of these equations. \
You now know ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["C", "1"], "(", "t", ")"}], "+", 
    RowBox[{
     SubscriptBox["C", "2"], "(", "t", ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4c31afdf-23ce-4373-920b-f82377b0943b"],
 " which will involve an integration constant you can call, ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c01f1095-0490-43ab-b3cd-28c2d374bdc9"],
 ", and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["C", "1"], "(", "t", ")"}], "-", 
    RowBox[{
     SubscriptBox["C", "2"], "(", "t", ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e43191ae-2b94-4aaf-8dad-638a10e6a13c"],
 " which will involve an integration constant you can call, ",
 Cell[BoxData[
  FormBox["b", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "94cb541c-12c8-48e4-8fc1-77c5520be8f9"],
 ".\n\n(c) If the initial condition is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["C", "1"], "(", "0", ")"}], "=", "1"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e8583258-af76-4c26-b8e2-6837124d365f"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["C", "2"], "(", "0", ")"}], "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6dcddae5-97f1-47a8-ac5a-5e9c3d64fa2e"],
 ", what are ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "40dda914-ec93-438b-8b60-85aa54cbc425"],
 " and ",
 Cell[BoxData[
  FormBox["b", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0ea62d30-557e-4272-b121-01bfb6fe81a8"],
 "?\n\n(d) This will take some work, but the final thing to do is to get some \
nice expressions for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["C", "1"], "(", "t", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "8804b383-a585-439c-abd3-00069a02c527"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["C", "2"], "(", "t", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b994dc1b-c194-4fd5-8f74-758b822088bf"],
 " for the initial conditions in (c).\n\nHINT: The final expression for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["C", "1"], "(", "t", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "85c1bc3e-073e-4e12-93ae-7fff30cc09dc"],
 " had two factors, and one of the factors was ",
 Cell[BoxData[
  FormBox[
   RowBox[{"cos", 
    FractionBox[
     RowBox[{"A", "\[VeryThinSpace]", "t"}], "\[HBar]"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "3d7318ee-ea83-4446-8c2d-3749cbe5933d"],
 "."
}], "Text",
 CellChangeTimes->{{3.983269812697874*^9, 3.983269831613324*^9}, {
  3.9832698640154057`*^9, 3.9832700944084682`*^9}, {3.983270132947373*^9, 
  3.983270184665784*^9}, {3.983270219337471*^9, 3.9832702472925177`*^9}, {
  3.983270306682502*^9, 3.983270414625515*^9}, {3.983270938296082*^9, 
  3.9832709803877*^9}},ExpressionUUID->"218687ad-228f-4bc7-9ef8-a49aa86fe085"],

Cell["", "PageBreak",
 PageBreakBelow->True,ExpressionUUID->"e488d630-edce-4344-9095-cafd51e1894e"]
}, Open  ]]
}, Open  ]],

