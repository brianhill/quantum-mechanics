   3.983219477497143*^9, 3.9832198054546757`*^9}, {3.983219841178533*^9, 
   3.983219932097743*^9}, {3.983219977793949*^9, 3.983220027307864*^9}, {
   3.983220069432619*^9, 3.983220087850245*^9}, {3.983220512527956*^9, 
   3.983220714283827*^9}, {3.983220763937693*^9, 3.9832207647884703`*^9}, {
   3.983220798453414*^9, 3.983220823503731*^9}, {3.9832210363813457`*^9, 
   3.983221262076695*^9}, {3.98322129334547*^9, 3.983221422647295*^9}, {
   3.983221487087933*^9, 3.9832216010252647`*^9}, {3.983221762761002*^9, 
   3.983221814570681*^9}, {3.983221849046213*^9, 3.983221863485489*^9}, {
