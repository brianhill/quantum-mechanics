Cell[CellGroupData[{

Cell["1. Black-body Radiation Formula Core Steps", "Subsection",
 CellChangeTimes->{{3.9723086371975727`*^9, 3.9723086523196497`*^9}, {
  3.9723092831466618`*^9, 3.972309284494011*^9}, {3.9789425501799192`*^9, 
  3.978942557594095*^9}, {3.978942593322667*^9, 3.9789426130599937`*^9}, {
  3.97894326680903*^9, 3.978943270435691*^9}, {3.979004319780263*^9, 
  3.9790043234386797`*^9}, {3.9790046277160187`*^9, 3.97900462978555*^9}, {
  3.979004974518355*^9, 3.9790049819762907`*^9}, {3.979027800710058*^9, 
  3.979027802278057*^9}, {3.983219466730739*^9, 3.983219474359612*^9}, {
  3.983219909446373*^9, 3.983219913104388*^9}, {3.9832217043479137`*^9, 
  3.983221706753545*^9}, {3.983222709653612*^9, 
  3.9832227128183327`*^9}},ExpressionUUID->"21bebf9a-ef11-4a05-8f7a-\
2678c4a46946"],

Cell["\<\
In this problem, I am just asking you to repeat part of the fundamental \
derivation from Chapter 4.\
\>", "Text",
 CellChangeTimes->{{3.983221677217806*^9, 3.983221681757279*^9}, {
  3.983222718237536*^9, 
  3.98322272276462*^9}},ExpressionUUID->"4b925ab0-662f-4d36-9dc4-\
2f271abbe75a"],

Cell[CellGroupData[{

Cell["(a) Application of Detailed Balance", "Subsubsection",
 CellChangeTimes->{{3.9832216539625807`*^9, 3.9832216591676607`*^9}, {
  3.983221696054439*^9, 
  3.983221701332367*^9}},ExpressionUUID->"eb49397f-95f0-4ab3-a0ee-\
be7380e13d46"],

Cell[TextData[{
 "After doing some already quite tricky arguments about photons as bosons, \
Feynman deduced that:\n\n(i) If ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["N", "g"], 
    OverscriptBox["n", "_"], " ", 
    SuperscriptBox[
     RowBox[{"\[LeftBracketingBar]", "a", "\[RightBracketingBar]"}], "2"]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "67c94745-9685-40f7-9705-4246b12c6cbd"],
 " is the rate at which photons are absorbed by ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["N", "g"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d3b46be6-f0e3-4d6c-9277-09288d22e9ee"],
 " atoms in the ground state,\n\n(ii) then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["N", "e"], "(", 
     RowBox[{
      OverscriptBox["n", "_"], "+", "1"}], ")"}], " ", 
    SuperscriptBox[
     RowBox[{"\[LeftBracketingBar]", "a", "\[RightBracketingBar]"}], "2"]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6fe537c7-249f-4eae-8ad2-8150b85b326f"],
 " is the rate at which photons are emitted by ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["N", "e"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "fb93417a-c1ac-4e11-b99c-07bb47ffa23e"],
 " atoms in an excited state.\n\nBy the Principle of Detailed Balance, these \
rates must be the same.\n\nJust equate the rates and cancel the unspecified \
amplitude-squared, ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"\[LeftBracketingBar]", "a", "\[RightBracketingBar]"}], "2"], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4e4fda32-8982-4836-8c5b-c97c1b63fea7"],
 "."
}], "Text",
 CellChangeTimes->{{3.972308733095611*^9, 3.972308775590413*^9}, {
   3.972308806899931*^9, 3.972308840005015*^9}, {3.978942617797345*^9, 
   3.978942798142323*^9}, {3.978942842111166*^9, 3.978942945175317*^9}, {
   3.978942979663383*^9, 3.978943073239522*^9}, {3.978943103823546*^9, 
   3.9789432555757313`*^9}, {3.9789432941898603`*^9, 3.978943396660392*^9}, {
   3.978951562925283*^9, 3.978951598090967*^9}, {3.97895162825675*^9, 
   3.978951846295452*^9}, {3.97895346033985*^9, 3.978953489527804*^9}, {
   3.979004368586997*^9, 3.979004450884747*^9}, {3.979004892548542*^9, 
