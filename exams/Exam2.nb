Cell[CellGroupData[{

Cell["(c) Rewriting Energies", "Subsubsection",
 CellChangeTimes->{{3.9832216539625807`*^9, 3.9832216591676607`*^9}, {
  3.983221696054439*^9, 3.983221701332367*^9}, {3.9832226783973103`*^9, 
  3.98322270464076*^9}, {3.9832227652884817`*^9, 
  3.983222774408375*^9}},ExpressionUUID->"5a034530-25de-4b0e-82ba-\
e81822fe1b1f"],

Cell[TextData[{
 "The energy difference between states, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalDelta]", "\[VeryThinSpace]", "E"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "8decc773-f0d0-4165-b7d2-bdae4549d81c"],
 ", is also the energy of the emitted or absorbed photon, ",
 Cell[BoxData[
  FormBox["\[HBar]\[Omega]", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "aeb117bf-3151-45aa-8aa1-9643ea0b01cb"],
 ", so substitute that into the formula for ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["n", "_"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "52f1d44f-e181-48cb-ae6d-651617ffddd9"],
 ".\n\nAlso, since these ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["n", "_"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "04773cdf-f448-40e9-88d6-d0792d4f0248"],
 " photons each have energy ",
 Cell[BoxData[
  FormBox["\[HBar]\[Omega]", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "05c62389-caec-4e73-b710-f4b39519b616"],
 ", to give the total energy of these ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["n", "_"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "487a045b-35de-4948-bb44-2d49856eb699"],
 " photons, just multiply your result for ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["n", "_"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "3f1ef076-6c94-4385-8038-f70ec978c4ce"],
 " by ",
 Cell[BoxData[
  FormBox["\[HBar]\[Omega]", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "8f854aeb-d3fd-4668-a2dd-fc9012f842f5"],
 ".\n\nNOTE: There was a lot of work preceding and following these core steps \
to get the final blackbody radiation formula. I\[CloseCurlyQuote]d encourage \
you to review it because it is remarkable and widely used. The work preceding \
involves important Bose statistics facts, and the work following involves the \
size of the box, and the number of allowed wavelengths in any given frequency \
interval."
}], "Text",
 CellChangeTimes->{{3.972308733095611*^9, 3.972308775590413*^9}, {
   3.972308806899931*^9, 3.972308840005015*^9}, {3.978942617797345*^9, 
