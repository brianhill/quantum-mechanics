Cell[TextData[{
 "This time have apparatus ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4a31068d-3034-45f3-81e2-b5791f68f6f3"],
 " spun by an angle \[Phi] about the ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4c1046a8-0c21-4e56-b5e8-9fee6a2eed50"],
 " axis.\n\nFirst, what do you expect for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["N", "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d81d56c2-e2b9-4f41-9908-254ca7e8adc2"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["N", "3"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b6703ae0-081d-43f2-a636-980e5f4a659c"],
 " if ",
 Cell[BoxData[
  FormBox["\[Phi]", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "679ace76-9aac-44ad-9f26-c7019f75ef00"],
 " is 0\.ba degrees or 180\.ba?\n\nNow just repeat the parts (a) and (b) that \
were asked in the previous problem but for this situation. This time, when \
you need entries like ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"<", 
     RowBox[{"+", "S"}]}], "|", 
    RowBox[{
     RowBox[{"+", "T"}], ">"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "827b5039-88ed-402f-9de6-e5154f6846b1"],
 ", because the entries for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["R", "x"], "(", "\[Phi]", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "08956d2f-681a-4c71-a7bb-33100dc66254"],
 " are complex, you will have to pay more attention to the complex \
conjugation in ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"<", "\[Psi]"}], "|", 
     RowBox[{"\[Chi]", ">"}]}], " ", "=", 
    RowBox[{
     RowBox[{"<", "\[Chi]"}], "|", 
     RowBox[{"\[Psi]", 
      SuperscriptBox[">", "*"]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f78110f1-0659-42a1-8169-cd33b79f2207"],
 "."
}], "Text",
 CellChangeTimes->{{3.9832595847010317`*^9, 3.9832596856560507`*^9}, {
  3.983259738835363*^9, 3.983259743889512*^9}, {3.983263537108054*^9, 
  3.983263541157098*^9}, {3.983263782626004*^9, 3.983264059474539*^9}, {
  3.983264540718645*^9, 3.983264588152069*^9}, {3.9832683274984217`*^9, 
  3.983268345290477*^9}, {3.983268737992539*^9, 3.983268894550765*^9}, {
  3.983268957119708*^9, 3.98326910372438*^9}, {3.983269162136972*^9, 
  3.983269209972301*^9}, {3.9832692405790043`*^9, 
  3.9832693868119173`*^9}},ExpressionUUID->"b766c258-730a-411f-8433-\
a153831263a7"],

Cell["", "PageBreak",
 PageBreakBelow->True,ExpressionUUID->"123fd2b2-5c40-4a5d-9cbe-1e2ed902afdf"]
}, Open  ]],

Cell[CellGroupData[{

Cell["4. Stationary States of Two-State Systems", "Subsection",
