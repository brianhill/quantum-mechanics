Cell[CellGroupData[{

Cell["(b) Incorporating Statistical Mechanics", "Subsubsection",
 CellChangeTimes->{{3.9832216539625807`*^9, 3.9832216591676607`*^9}, {
  3.983221696054439*^9, 3.983221701332367*^9}, {3.9832226783973103`*^9, 
  3.98322270464076*^9}, {3.983227799774233*^9, 
  3.983227799997121*^9}},ExpressionUUID->"f2ece8be-6c55-4280-a33b-\
f0438cd45453"],

Cell[TextData[{
 "A fundamental result from statistical mechanics is that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     SubscriptBox["N", "e"], 
     SubscriptBox["N", "g"]], "=", 
    SuperscriptBox["e", 
     RowBox[{
      RowBox[{"-", "\[CapitalDelta]"}], "\[VeryThinSpace]", 
      RowBox[{"E", "/", "k"}], "\[VeryThinSpace]", "T"}]]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "81207b73-9582-478d-8199-e710a240c410"],
 ". Use this fundamental result and your answer from (a) to get a formula for \
",
 Cell[BoxData[
  FormBox[
   OverscriptBox["n", "_"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "52d69d69-d65e-4a8c-8a17-23e40ff5c53b"],
 "."
}], "Text",
 CellChangeTimes->{{3.972308733095611*^9, 3.972308775590413*^9}, {
   3.972308806899931*^9, 3.972308840005015*^9}, {3.978942617797345*^9, 
