Cell[BoxData[{
 RowBox[{
  RowBox[{"L", "=", "4"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"c", "[", 
    RowBox[{"x_", ",", "n_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"Sqrt", "[", 
     FractionBox["2", "L"], "]"}], 
    RowBox[{"Cos", "[", 
     FractionBox[
      RowBox[{"n", "\[VeryThinSpace] ", "Pi", " ", "x"}], "L"], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tableOfCoefficients", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"\[Psi]", "[", "x", "]"}], 
        RowBox[{"c", "[", 
         RowBox[{"x", ",", "n"}], "]"}]}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"x", ",", " ", 
         FractionBox[
          RowBox[{"-", "L"}], "2"], ",", 
