Cell["\<\
Is it not remarkable that out of the following three cosines, we were able to \
make a polynomial of degree 6 that was reasonably localized?\
\>", "Text",
 CellChangeTimes->{{3.980805389314942*^9, 3.980805433339835*^9}, {
  3.980805814850998*^9, 3.980805830603026*^9}, {3.980806026048867*^9, 
  3.9808060509447403`*^9}},ExpressionUUID->"5929cb84-9969-4fcc-94a0-\
16568fd1fda6"],

