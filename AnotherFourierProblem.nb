Cell[TextData[{
 "Apply the powerful mathematics of Fourier analysis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"n", "=", "1"}], ",", " ", "3", ",", " ", "5"}], 
   TraditionalForm]],ExpressionUUID->"15892e6f-7d18-478c-9df0-e87db307589e"],
 ":"
}], "Text",
 CellChangeTimes->{{3.9774848339897337`*^9, 3.9774848607646503`*^9}, {
   3.977484927744688*^9, 3.9774850172470627`*^9}, {3.977486488535474*^9, 
   3.977487002002028*^9}, {3.977487032886286*^9, 3.977487041522026*^9}, 
   3.977487077838335*^9, {3.977487132003697*^9, 3.9774871324542837`*^9}, {
   3.977487238050396*^9, 3.9774874168568783`*^9}, {3.980609860842248*^9, 
   3.980609872855412*^9}, {3.980610981034216*^9, 3.980610999165991*^9}, {
   3.980612279123908*^9, 3.980612408054124*^9}, {3.980612501992551*^9, 
   3.980612502265012*^9}, {3.9806125393464813`*^9, 3.980612684014167*^9}, {
   3.9806127175420513`*^9, 3.9806128289693317`*^9}, {3.980619784885008*^9, 
   3.980619804550033*^9}, {3.980619847049222*^9, 3.98061985135075*^9}, {
   3.980621217755962*^9, 3.9806213272639313`*^9}, {3.980798847248066*^9, 
   3.98079890129233*^9}, {3.980799427202415*^9, 3.9807995407454157`*^9}, {
