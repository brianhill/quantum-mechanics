Cell["Square this function to get a probability distribution:", "Text",
 CellChangeTimes->{{3.980800288989952*^9, 
  3.980800301275943*^9}},ExpressionUUID->"59cec324-4a69-468b-9af4-\
7a476649eb89"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"prob", "[", "x_", "]"}], ":=", 
   FormBox[
    SuperscriptBox[
     RowBox[{"\[Psi]", "[", "x", "]"}], "2"],
    TraditionalForm]}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"prob", "[", "x", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", " ", 
     RowBox[{"-", "2"}], ",", " ", "2"}], "}"}]}], "]"}]}], "Input",
