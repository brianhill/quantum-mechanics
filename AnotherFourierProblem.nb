Cell[CellGroupData[{

Cell["\<\
YOUR FINAL CHECK \[LongDash] Normalization \[LongDash] Integrate the Square \
of the First Three Terms\
\>", "Subsection",
 CellChangeTimes->{{3.9806201659244947`*^9, 3.9806201725211687`*^9}, {
  3.980620655368862*^9, 3.980620661125619*^9}, {3.9808043316118307`*^9, 
  3.980804332269306*^9}, {3.980804457904525*^9, 3.980804464907146*^9}, {
  3.9808044970558023`*^9, 3.980804511588293*^9}, {3.980805368076775*^9, 
  3.980805371191107*^9}, {3.980805589108117*^9, 
  3.98080559067992*^9}},ExpressionUUID->"93c35acf-4690-4a78-b370-\
013be51ab97a"],

Cell["\<\
Double-check that your mathematics agrees with mine by doing the integral \
that should come out very near 1, and would quickly get even closer to 1 if \
we included more terms:\
\>", "Text",
 CellChangeTimes->{{3.980805389314942*^9, 3.980805433339835*^9}, {
  3.9808063826562757`*^9, 
  3.980806383717195*^9}},ExpressionUUID->"9af54966-8dc5-4d12-9392-\
95e300fcf2a5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"N", "[", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"threeTerms", "[", "x", "]"}], ")"}], "2"], ",", " ", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "2"}], ",", " ", "2"}], "}"}]}], "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.980620178885251*^9, 3.980620258072414*^9}, {
  3.980620333617483*^9, 3.980620333749106*^9}, {3.980621515736971*^9, 
  3.980621522259501*^9}, {3.980804476361483*^9, 3.9808044834943647`*^9}, {
  3.980804528004035*^9, 3.980804541545827*^9}},
 CellLabel->"In[55]:=",ExpressionUUID->"f11c30cd-4525-470e-86b4-4726b33b11b7"],

