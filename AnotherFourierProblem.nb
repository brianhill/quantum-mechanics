787cd7e4a561"],

Cell[TextData[{
 "Again, the only cosines we have to consider are ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox[
     SqrtBox[
      FractionBox["2", "L"]],
     FontSize->14], "cos", " ", 
    FractionBox[
     RowBox[{"n", " ", "\[Pi]", " ", "x"}], "L"]}], TraditionalForm]],
  ExpressionUUID->"83e4a8a5-fe7f-4cde-87b4-27796ec32f0c"],
 " where ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "f8e72a10-8952-4bf9-a73c-53666f8befe1"],
 " is any odd integer. Here are the first three of those functions:"
}], "Text",
 CellChangeTimes->{{3.9774848339897337`*^9, 3.9774848607646503`*^9}, {
