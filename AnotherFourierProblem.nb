Notebook[{
Cell["Another Fourier Problem", "Section",
 CellChangeTimes->{{3.980612196187374*^9, 3.980612211422606*^9}, {
  3.980798807419237*^9, 
  3.980798811496584*^9}},ExpressionUUID->"821ff873-b417-423b-a8a4-\
5a0d4019d7d8"],

Cell[CellGroupData[{

Cell[TextData[StyleBox["A Fourier Localization Problem with no Ringing",
 FontSize->18,
 FontSlant->"Italic"]], "Subtitle",
 CellChangeTimes->{{3.980620822912372*^9, 3.980620841363928*^9}, {
  3.9807988147235413`*^9, 3.9807988178885593`*^9}, {3.980799660779619*^9, 
  3.9807996712204027`*^9}},ExpressionUUID->"f6dfc8ec-0d99-468b-8cc0-\
97de10843fd0"],

Cell[TextData[StyleBox["For Quantum Mechanics, Monday, Mar. 16, 2026",
 FontSize->18,
 FontSlant->"Italic"]], "Subtitle",
 CellChangeTimes->{{3.980620822912372*^9, 3.980620841363928*^9}, {
  3.9807988147235413`*^9, 3.9807988178885593`*^9}, {3.980799660779619*^9, 
  3.980799679816391*^9}, {3.980807425836669*^9, 
  3.980807430233615*^9}},ExpressionUUID->"cfc20ab9-f802-4f42-a532-\
dae68ab4fb47"],

Cell[CellGroupData[{

Cell["The Function to Approximate With Cosines", "Subsection",
 CellChangeTimes->{{3.9806122473340683`*^9, 3.980612272489726*^9}, {
  3.980621887390874*^9, 3.980621887513867*^9}, {3.980798824368395*^9, 
  3.980798841992577*^9}, {3.9807997868201103`*^9, 
  3.980799801050418*^9}},ExpressionUUID->"6a4e3784-791d-4a23-8155-\
178ac5fb54a3"],

Cell[TextData[{
 "An issue with our first and easiest example of localization (a \
step-up-and-step-down function that was nonzero only between ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", 
     FractionBox["L", "8"]}], " ", "and", " ", 
    FractionBox["L", "8"]}], TraditionalForm]],ExpressionUUID->
  "579ca459-59a5-47da-84ff-500515275816"],
 ") appeared at the discontinuities.\n\nIt is difficult for a bunch of \
continuous functions (in this case the sum of any number of cosines) to \
well-approximate any function with a discontinuity, even if the function is \
even and vanishes at the edge of the box.\n\nThe function when approximated \
by cosines exhibits ringing.\n\nHere and below, I will frequently specialize \
to the case ",
 Cell[BoxData[
  FormBox[
   RowBox[{"L", "=", "4"}], TraditionalForm]],ExpressionUUID->
  "7d74a29d-4716-4613-b990-d04c764d3cfd"],
 " for definiteness. The box then goes from ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", "2"}], " ", "to", " ", "2"}], TraditionalForm]],
  ExpressionUUID->"56daeb47-05b4-4369-a7ff-4c0c24e964f8"],
 ".\n\nHere is a polynomial of degree six, that is concentrated on ",
 Cell[BoxData[
  FormBox[
   RowBox[{"[", 
    RowBox[{
     RowBox[{"-", "1"}], ",", " ", "1"}], "]"}], TraditionalForm]],
  ExpressionUUID->"91a68beb-3ed6-4160-b829-2f4ccff5d3aa"],
 ", and small on ",
 Cell[BoxData[
  FormBox[
   RowBox[{"[", 
    RowBox[{
     RowBox[{"-", "2"}], ",", " ", 
     RowBox[{"-", "1"}]}], "]"}], TraditionalForm]],ExpressionUUID->
  "ab1e98e2-14fa-40f5-81b0-20abde683209"],
 " and on  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"[", 
    RowBox[{"1", ",", " ", "2"}], "]"}], TraditionalForm]],ExpressionUUID->
  "2bce647c-f2c1-4f42-af61-19bb9c393536"],
 ":"
}], "Text",
 CellChangeTimes->{{3.9774848339897337`*^9, 3.9774848607646503`*^9}, {
   3.977484927744688*^9, 3.9774850172470627`*^9}, {3.977486488535474*^9, 
   3.977487002002028*^9}, {3.977487032886286*^9, 3.977487041522026*^9}, 
   3.977487077838335*^9, {3.977487132003697*^9, 3.9774871324542837`*^9}, {
   3.977487238050396*^9, 3.9774874168568783`*^9}, {3.980609860842248*^9, 
   3.980609872855412*^9}, {3.980610981034216*^9, 3.980610999165991*^9}, {
   3.980612279123908*^9, 3.980612408054124*^9}, {3.980612501992551*^9, 
   3.980612502265012*^9}, {3.9806125393464813`*^9, 3.980612684014167*^9}, {
   3.9806127175420513`*^9, 3.9806128289693317`*^9}, {3.980619784885008*^9, 
   3.980619804550033*^9}, {3.980619847049222*^9, 3.98061985135075*^9}, {
   3.980621217755962*^9, 3.9806213272639313`*^9}, {3.980798847248066*^9, 
   3.98079890129233*^9}, {3.980799427202415*^9, 3.980799558565209*^9}, {
   3.9807997375842648`*^9, 3.980799749074347*^9}, {3.980799779976241*^9, 
   3.980799780546575*^9}, {3.980799810923637*^9, 3.980799885597867*^9}, {
   3.980799976761093*^9, 3.980800107582312*^9}, {3.9808001379899263`*^9, 
   3.980800222606032*^9}, {3.980804691703519*^9, 
   3.9808048661042843`*^9}},ExpressionUUID->"ff94d879-65bb-4584-9319-\
79981658d393"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\n", 
  RowBox[{
   FormBox[
    RowBox[{
     RowBox[{"\[Psi]", "[", "x_", "]"}], ":=", 
     RowBox[{
      FractionBox[
       SqrtBox["3003"], "64"], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"1", "-", 
         FractionBox[
          SuperscriptBox["x", "2"], "4"]}], ")"}], "3"]}]}],
    TraditionalForm], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"\[Psi]", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", 
       RowBox[{"-", "2"}], ",", " ", "2"}], "}"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.980799551140272*^9, 3.9807995910584717`*^9}, {
  3.980800151193761*^9, 3.980800151924879*^9}},
 CellLabel->"In[17]:=",ExpressionUUID->"ccfd625e-01bc-4915-9852-8f2d24efe47c"],

