  3.980623383269524*^9}},ExpressionUUID->"7e24666b-cd45-4b65-bb0e-\
39d37e4dff22"],

Cell[CellGroupData[{

Cell["Assembling the Series \[LongDash] Third and Fourth Non-Zero Terms", \
"Subsubsection",
 CellChangeTimes->{{3.9806201659244947`*^9, 3.9806201725211687`*^9}, {
  3.980620655368862*^9, 3.980620661125619*^9}, {3.980818741819826*^9, 
  3.980818781946268*^9}, {3.980818813027437*^9, 3.9808188202565937`*^9}, {
  3.98081903524856*^9, 
  3.980819036673456*^9}},ExpressionUUID->"0ca83c70-6a7e-4a9c-b9cd-\
4120c46d788e"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"f4", "[", "x_", "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{"tableOfCoefficients", "[", 
      RowBox[{"[", "1", "]"}], "]"}], 
     RowBox[{"c", "[", 
      RowBox[{"x", ",", "1"}], "]"}]}], "+", 
    RowBox[{
     RowBox[{"tableOfCoefficients", "[", 
      RowBox[{"[", "2", "]"}], "]"}], 
     RowBox[{"c", "[", 
      RowBox[{"x", ",", "3"}], "]"}]}], " ", "+", " ", 
    RowBox[{
     RowBox[{"tableOfCoefficients", "[", 
      RowBox[{"[", "3", "]"}], "]"}], " ", 
     RowBox[{"c", "[", 
      RowBox[{"x", ",", "5"}], "]"}]}], "+", 
    RowBox[{
     RowBox[{"tableOfCoefficients", "[", 
      RowBox[{"[", "4", "]"}], "]"}], " ", 
     RowBox[{"c", "[", 
      RowBox[{"x", ",", "7"}], "]"}]}]}]}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"f4", "[", "x", "]"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "2"}], ",", " ", "2"}], "}"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.980620178885251*^9, 3.980620258072414*^9}, {
  3.980620333617483*^9, 3.980620333749106*^9}, {3.980818857429884*^9, 
  3.980818887446583*^9}, {3.9808189302047577`*^9, 3.980818937286139*^9}, {
  3.980818971271585*^9, 3.980818985835927*^9}},
