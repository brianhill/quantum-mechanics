Cell[CellGroupData[{

Cell["Assembling the Series \[LongDash] Eight Non-Zero Terms", "Subsubsection",
 CellChangeTimes->{{3.9806201659244947`*^9, 3.9806201725211687`*^9}, {
  3.980620655368862*^9, 3.980620661125619*^9}, {3.980818741819826*^9, 
