Cell[TextData[{
 "Note that coefficient 2 multiplies the cosine with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "=", "3"}], TraditionalForm]],ExpressionUUID->
  "0b182f86-8273-4a21-b504-7d3cfcdd31db"],
 ", coefficient 3 multiplies the cosine with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "=", "5"}], TraditionalForm]],ExpressionUUID->
  "8b624239-243a-4035-a345-37d382e83df9"],
 ", ",
 StyleBox["etc.\n\n",
  FontSlant->"Italic"],
 "Here is the localized function being built up two terms:"
}], "Text",
 CellChangeTimes->{{3.98062013026538*^9, 3.980620145281402*^9}, {
  3.9806206720185757`*^9, 3.9806207418182373`*^9}, {3.980621372506095*^9, 
  3.980621456149762*^9}},ExpressionUUID->"de94500f-f6ef-4281-80ac-\
088a9a861a39"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"tableOfCoefficients", "[", 
      RowBox[{"[", "1", "]"}], "]"}], 
     RowBox[{"c", "[", 
      RowBox[{"x", ",", "1"}], "]"}]}], "+", 
    RowBox[{
     RowBox[{"tableOfCoefficients", "[", 
      RowBox[{"[", "2", "]"}], "]"}], 
     RowBox[{"c", "[", 
      RowBox[{"x", ",", "3"}], "]"}]}]}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "2"}], ",", " ", "2"}], "}"}]}], "]"}]], "Input",
