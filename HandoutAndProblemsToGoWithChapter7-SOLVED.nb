Cell[TextData[{
 StyleBox["FOR YOU \[LongDash] Find some graphing program and do another term \
or two in the series \[LongDash] graph both the function and its square. The \
numerical values of the table of coefficients might be easier to use than the \
exact ones. Also, note that I have chosen ",
  FontSize->18,
  FontSlant->"Italic"],
 Cell[BoxData[
  FormBox[
   RowBox[{"L", "=", "4"}], TraditionalForm]],
  FontSize->18,
  FontSlant->"Italic",ExpressionUUID->
  "55cc7c74-6f10-4bbc-8f45-8b5e8827a91f"],
 StyleBox[" so your graphs will go from ",
  FontSize->18,
  FontSlant->"Italic"],
 Cell[BoxData[
  FormBox[
   RowBox[{"-", "2"}], TraditionalForm]],
  FontSize->18,
  FontSlant->"Italic",ExpressionUUID->
  "5b5e705c-7c59-416e-a6c7-e9492fe7bac5"],
 StyleBox[" to ",
  FontSize->18,
  FontSlant->"Italic"],
 Cell[BoxData[
  FormBox["2", TraditionalForm]],
  FontSize->18,
  FontSlant->"Italic",ExpressionUUID->
  "c6d5fc52-44e4-423a-81d3-473533edb3a8"],
 StyleBox[".",
  FontSize->18,
  FontSlant->"Italic"]
}], "Subsubsection",
 CellChangeTimes->{{3.9806201659244947`*^9, 3.9806201725211687`*^9}, {
  3.980620655368862*^9, 3.980620661125619*^9}, {3.980621561861392*^9, 
  3.980621588036968*^9}, {3.980621794330041*^9, 3.980621795318151*^9}, {
